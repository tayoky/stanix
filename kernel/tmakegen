#!/bin/sh

NAME=kernel

SCRIPT="$(realpath "$0")"
cd "$(dirname "$0")"
BUILDDIR="$(realpath ../build)"
TMAKE=$(realpath "../scripts/tmake.sh")
DIR="$PWD"
. "$TMAKE"

tmake_init "$@"

echo '
KLIBC ?= $(BUILDDIR)/tlibc/static-libk/libk.a

# freestanding flags
CFLAGS += -Wall \
    -Wextra \
    -std=gnu11 \
    -ffreestanding \
    -fno-stack-protector \
    -fno-stack-check \
    -fno-PIC \
	-fno-omit-frame-pointer \
    -fsanitize=undefined \
    -D__KERNEL__=1
CFLAGS += -I ./include/
CFLAGS += -I ../limine/

LDFLAGS += \
	-nostdlib \
	-static \
	-z max-page-size=0x1000 \
	-T arch/$(ARCH)/linker.ld

# arch specific flags
-include arch/$(ARCH)/arch.mk' >> "$MAKEFILE"

DIRS="drivers fs klib mem task"
tmake_add_executable "kernel" $(find $DIRS -name "*.c" | sort) *.c "\$(shell find arch/\$(ARCH) -name \"*.c\" -or -name \"*.s\")" HAVE_GEN_C=yes DDEPENDENCIES="\$(BUILDDIR)/kernel/sym.c.o \$(KLIBC)"

echo "
# sym.c is an automatically generated table
\$(BUILDDIR)/kernel/sym.c : \$(OBJ_kernel) \$(KLIBC)
	@echo \"GEN sym.c\"
	@echo '#include <kernel/sym.h>' > \$@
	@\$(foreach SYM , \$(shell \$(NM) \$^ --defined-only -ngj --quiet ),  echo \"extern void \$(SYM) ();\" >> \$@; )
	@echo 'const sym_t symbols[] = {' >> \$@
	@\$(foreach SYM , \$(shell \$(NM) \$^ --defined-only -ngj --quiet ),  echo \"	{ .name = \\\"\$(SYM)\\\" , .value = (uintptr_t)\$(SYM) , .size = sizeof(\$(SYM))},\" >> \$@; ) 
	@echo '};' >> \$@
	@echo 'const size_t symbols_count = sizeof(symbols) / sizeof(sym_t);' >> \$@" >> "$MAKEFILE"

tmake_add_data "headers" "include/kernel" $(find include -name "*.h" | sort) "../limine/limine.h"

tmake_fini
