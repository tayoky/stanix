#!/bin/sh

. scripts/tconf.sh

# automaticly add toolchain/bin to path
if test -d "$(dirname $0)/toolchain/bin" ; then
  export PATH="$(realpath $(dirname $0))/toolchain/bin:$PATH"
fi

# defaults
test -z "$SYSROOT" && SYSROOT="sysroot"
test -z "$PREFIX" && PREFIX="$SYSROOT/usr"
if test "$(uname || echo unknow)" != "Stanix" ; then
	# if we are not on stanix we need a cross toolchain
	CROSS_TOOLCHAIN="yes"
fi

# default host
test -z "$HOST" && HOST="$(uname -m)-stanix"
test -z "$CFLAGS" && CFLAGS=-O2

tconf_init "$@"

if test "$CROSS_TOOLCHAIN" = "yes" ; then
	# we need to build a cross toolchain
	if ! scripts/build-toolchain.sh --target="$HOST" --sysroot="$SYSROOT" ; then
		echo "could not build cross toolchain"
		exit 1
	fi
fi

# check tools
tconf_search_cc "$HOST"
tconf_search_as "$HOST"
tconf_search_ar "$HOST"
tconf_search_ld "$HOST"
tconf_search_nm "$HOST"
tconf_find_os
ARCH=${HOST%%-*}
if test "$ARCH" = "x86_64" ; then
	tconf_search_util "NASM" "nasm" "" nasm
fi

# propagate configuration to tlibc and ports
if [ ! -f ./tlibc/configure ] ; then
	git submodule init
	git submodule update tlibc
fi

tconf_add_subdir tlibc --enable-dynamic

if [ ! -f ./ports/configure ] ; then
	git submodule init
	git submodule update ports
fi

tconf_add_subdir ports

if [ ! -f ./libraries/libtgui/configure ] ; then
	git submodule init
	git submodule update ports
fi

tconf_add_subdir libraries/libtgui

echo "using $SYSROOT as sysroot"

tconf_fini
echo "NASM=$NASM" >> config.mk
