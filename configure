#!/bin/sh

. ./tconf.sh

# automaticly add toolchain/bin to path
if [ -d "$(dirname $0)/toolchain/bin" ] ; then
  export PATH="$(realpath $(dirname $0))/toolchain/bin:$PATH"
fi

# defaults
test -z "$SYSROOT" && SYSROOT="$(dirname "$(realpath "$0")")/sysroot"
test -z "$PREFIX" && PREFIX="$(realpath "$SYSROOT/"usr)"

#default host
test -z "$HOST" && HOST="$(uname -m)-stanix"
test -z "$CFLAGS" && CFLAGS=-O2

tconf_init "$@"

# check tools
tconf_search_cc "$HOST"
tconf_search_as "$HOST"
tconf_search_ld "$HOST"
tconf_search_nm "$HOST"
tconf_find_os
ARCH=${HOST%%-*}
if test "$ARCH" = "x86_64" ; then
	tconf_search_util "NASM" "nasm" "" nasm
fi

# propagate configuration to tlibc and ports
if [ ! -f ./tlibc/configure ] ; then
	git submodule init
	git submodule update tlibc
fi

tconf_add_subdir tlibc --enable-dynamic

if [ ! -f ./ports/configure ] ; then
	git submodule init
	git submodule update ports
fi

tconf_add_subdir ports

echo "using $SYSROOT as sysroot"

tconf_fini
echo "NASM=$NASM" >> config.mk
